rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /albums/{albumId}/{allPaths=**} {
      // Same album membership as Firestore (default database).
      allow read, write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/albums/$(albumId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/albums/$(albumId)).data.memberIds;
    }
  }
}
