rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function albumMemberIds(albumId) {
      return get(/databases/$(database)/documents/albums/$(albumId)).data.memberIds;
    }

    /** Used for memories/invites (different docs). Never call on the album collection itself in a query rule. */
    function isAlbumMemberId(albumId) {
      return signedIn()
        && albumId is string
        && exists(/databases/$(database)/documents/albums/$(albumId))
        && request.auth.uid in albumMemberIds(albumId);
    }

    /** Accept emailed invite: batch does arrayUnion(uid) before uid is in memberIds. */
    function isJoiningAlbumAsSelf() {
      return signedIn()
        && request.resource.data.title == resource.data.title
        && request.resource.data.createdBy == resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds
        && !(request.auth.uid in resource.data.memberIds)
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /albums/{albumId} {
      // For LIST queries: query is `where("memberIds","array-contains", auth.uid)`,
      // which exactly matches `request.auth.uid in resource.data.memberIds`.
      // Don't add type checks here — they break the query analyzer.
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if signedIn()
        && request.resource.data.title is string
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if signedIn() && (
        request.auth.uid in resource.data.memberIds ||
        isJoiningAlbumAsSelf()
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /memories/{memoryId} {
      // For LIST queries: query is `where("albumId","==", X)`. We can't statically
      // tie X to membership, so memories are only listable via the same membership get().
      allow read: if signedIn() && isAlbumMemberId(resource.data.albumId);

      allow create: if signedIn()
        && request.resource.data.albumId is string
        && (request.resource.data.type == "polaroid" || request.resource.data.type == "orb")
        && request.resource.data.createdBy == request.auth.uid
        && isAlbumMemberId(request.resource.data.albumId);

      allow update, delete: if signedIn() && isAlbumMemberId(resource.data.albumId);
    }

    match /albumInvites/{inviteId} {
      // Invite doc id is `<albumId>__<lowercased email>`; users may only read THEIR
      // invite by exact id from acceptPendingInvitesForUser (single getDoc), or list
      // them as an album member.
      allow get: if signedIn() && (
        (request.auth.token.email is string
          && resource.data.email == request.auth.token.email.lower()) ||
        isAlbumMemberId(resource.data.albumId)
      );

      allow list: if signedIn() && isAlbumMemberId(resource.data.albumId);

      allow create: if signedIn()
        && request.resource.data.albumId is string
        && request.resource.data.email is string
        && request.resource.data.createdBy == request.auth.uid
        && isAlbumMemberId(request.resource.data.albumId);

      allow delete: if signedIn() && (
        (request.auth.token.email is string
          && resource.data.email == request.auth.token.email.lower()) ||
        isAlbumMemberId(resource.data.albumId)
      );
    }
  }
}
