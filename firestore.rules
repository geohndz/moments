rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function albumData(albumId) {
      return get(/databases/$(database)/documents/albums/$(albumId)).data;
    }

    function isAlbumMember(albumId) {
      return signedIn() && request.auth.uid in albumData(albumId).memberIds;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /albums/{albumId} {
      allow read: if isAlbumMember(albumId);
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["title", "memberIds", "createdBy", "createdAt"])
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAlbumMember(albumId);
      allow delete: if signedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /memories/{memoryId} {
      allow read: if signedIn() && isAlbumMember(resource.data.albumId);

      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["albumId", "type", "title", "date", "createdBy", "createdAt"])
        && request.resource.data.albumId is string
        && (request.resource.data.type == "polaroid" || request.resource.data.type == "orb")
        && isAlbumMember(request.resource.data.albumId)
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn() && isAlbumMember(resource.data.albumId);
    }

    match /albumInvites/{inviteId} {
      allow read: if signedIn() && (
        request.auth.token.email == resource.data.email ||
        isAlbumMember(resource.data.albumId)
      );

      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["albumId", "email", "createdBy", "createdAt"])
        && isAlbumMember(request.resource.data.albumId)
        && request.resource.data.createdBy == request.auth.uid;

      allow delete: if signedIn() && (
        request.auth.token.email == resource.data.email ||
        isAlbumMember(resource.data.albumId)
      );
    }
  }
}
