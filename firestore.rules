rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function albumMemberIds(albumId) {
      return get(/databases/$(database)/documents/albums/$(albumId)).data.memberIds;
    }

    /** Use get() only when reading *other* docs (memories, invites), not the album doc itself. */
    function isAlbumMemberId(albumId) {
      return signedIn()
        && albumId is string
        && exists(/databases/$(database)/documents/albums/$(albumId))
        && request.auth.uid in albumMemberIds(albumId);
    }

    /** Accept emailed invite: batch does arrayUnion(uid) before uid is in memberIds. */
    function isJoiningAlbumAsSelf(albumId) {
      return signedIn()
        && request.resource.data.memberIds is list
        && resource.data.memberIds is list
        && request.resource.data.title == resource.data.title
        && request.resource.data.createdBy == resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds
        && !(request.auth.uid in resource.data.memberIds)
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1;
    }

    /** Invites store lowercase email; token casing may differ (e.g. Gmail). */
    function inviteEmailMatchesAuth() {
      return request.auth.token.email is string
        && resource.data.email == request.auth.token.email.lower();
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /albums/{albumId} {
      // List + get: avoid get(self) — use resource.memberIds (works with array-contains queries).
      allow read: if signedIn()
        && resource.data.memberIds is list
        && request.auth.uid in resource.data.memberIds;

      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["title", "memberIds", "createdBy"])
        && request.resource.data.title is string
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if signedIn() && (
        (resource.data.memberIds is list && request.auth.uid in resource.data.memberIds) ||
        isJoiningAlbumAsSelf(albumId)
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /memories/{memoryId} {
      allow read: if signedIn() && isAlbumMemberId(resource.data.albumId);

      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["albumId", "type", "title", "date", "createdBy"])
        && request.resource.data.albumId is string
        && (request.resource.data.type == "polaroid" || request.resource.data.type == "orb")
        && isAlbumMemberId(request.resource.data.albumId)
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn() && isAlbumMemberId(resource.data.albumId);
    }

    match /albumInvites/{inviteId} {
      allow read: if signedIn() && (
        inviteEmailMatchesAuth() ||
        isAlbumMemberId(resource.data.albumId)
      );

      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["albumId", "email", "createdBy"])
        && request.resource.data.albumId is string
        && request.resource.data.email is string
        && isAlbumMemberId(request.resource.data.albumId)
        && request.resource.data.createdBy == request.auth.uid;

      allow delete: if signedIn() && (
        inviteEmailMatchesAuth() ||
        isAlbumMemberId(resource.data.albumId)
      );
    }
  }
}
